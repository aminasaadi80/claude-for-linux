{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Claude for Linux",
  "mainBinaryName": "claude-linux",
  "version": "0.5.0",
  "identifier": "com.amin.claude-linux",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Claude for Linux",
        "width": 1040,
        "height": 720,
        "minWidth": 600,
        "minHeight": 480
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb"],
    "category": "Development",
    "shortDescription": "GUI for Claude on Linux",
    "linux": {
      "deb": {
        "depends": ["wl-clipboard | xclip"]
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
